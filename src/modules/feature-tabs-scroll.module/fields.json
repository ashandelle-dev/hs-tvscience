  {
    "name": "behavior",
    "label": "Scroll behavior",
    "type": "group",
    "tab": "CONTENT",
    "children": [
      {
        "name": "pin_enabled",
        "label": "Pin to viewport on desktop",
        "type": "boolean",
        "display": "toggle",
        "inline_help_text": "When on, the section sticks while user scrolls through each state. Disable for in-flow click-to-switch behavior.",
        "default": true
      },
      {
        "name": "scroll_distance_per_tab",
        "label": "Scroll distance per tab (vh)",
        "type": "number",
        "suffix": "vh",
        "min": 50,
        "max": 200,
        "inline_help_text": "How many viewport heights of scrolling each tab takes. 100 = 1 full screen of scrolling per tab. Lower = faster transitions.",
        "default": 100
      }
    ]
  },

  {
    "name": "style",
    "label": "Style",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "name": "background_color",
        "label": "Background color",
        "type": "color",
        "default": { "color": "#FFFFFF", "opacity": 100 }
      },
      {
        "name": "background_image",
        "label": "Background image",
        "type": "image",
        "default": { "size_type": "auto", "src": "", "alt": "", "loading": "lazy" }
      },
      {
        "name": "text_color",
        "label": "Text color",
        "type": "color",
        "default": { "color": null, "opacity": 100 }
      },
      {
        "name": "padding",
        "label": "Padding",
        "type": "spacing",
        "default": {
          "padding": {
            "top":    { "value": 80, "units": "px" },
            "bottom": { "value": 80, "units": "px" }
          }
        }
      }
    ]
  }
]
