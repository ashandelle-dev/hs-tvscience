[
  {
    "name": "heading",
    "label": "Heading",
    "type": "group",
    "tab": "CONTENT",
    "children": [
      {
        "name": "value",
        "label": "Heading content",
        "type": "text",
        "allow_new_line": false,
        "default": "Finally — a TV advertising platform that empowers you (and your ads) to perform"
      },
      {
        "name": "header_tag",
        "label": "Heading level",
        "type": "choice",
        "required": true,
        "display": "select",
        "choices": [["h1", "H1"], ["h2", "H2"], ["h3", "H3"], ["h4", "H4"], ["h5", "H5"], ["h6", "H6"], ["p", "P"]],
        "default": "h2"
      },
      {
        "name": "heading_size",
        "label": "Heading Size",
        "type": "number",
        "suffix": "px",
        "inline_help_text": "Set to 0 to use the default size",
        "default": 32
      },
      {
        "name": "heading_size_mobile",
        "label": "Heading Size Mobile",
        "type": "number",
        "suffix": "px",
        "inline_help_text": "Set to 0 to use the default size",
        "default": 26
      },
      {
        "name": "font_weight",
        "label": "Font Weight",
        "type": "choice",
        "display": "select",
        "choices": [["normal", "Normal"], ["medium", "Medium"], ["semibold", "Semibold"], ["bold", "Bold"]],
        "default": "medium"
      },
      {
        "name": "max_width",
        "label": "Heading max-width (px)",
        "type": "number",
        "suffix": "px",
        "inline_help_text": "Caps the heading text wrap so it forms a tighter block. Set to 0 for full width.",
        "default": 600
      }
    ]
  },

  {
    "name": "tabs",
    "label": "Tabs / Pillars",
    "type": "group",
    "tab": "CONTENT",
    "occurrence": {
      "min": 2,
      "max": 5,
      "default": 3,
      "sorting_label_field": "tabs.tab_label"
    },
    "children": [
      {
        "name": "tab_label",
        "label": "Tab label",
        "type": "text",
        "allow_new_line": false,
        "default": "Scalability"
      },
      {
        "name": "tab_icon",
        "label": "Tab icon (shown when active, ~35×35)",
        "type": "image",
        "responsive": false,
        "resizable": true,
        "default": {
          "size_type": "exact",
          "src": "",
          "alt": "",
          "loading": "lazy",
          "width": 35,
          "height": 35
        }
      },
      {
        "name": "tab_image",
        "label": "Right-side composite image",
        "type": "image",
        "responsive": true,
        "resizable": true,
        "default": {
          "size_type": "auto",
          "src": "",
          "alt": "",
          "loading": "lazy",
          "width": 0,
          "height": 0
