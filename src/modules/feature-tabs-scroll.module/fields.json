        "tab_image": { "size_type": "auto", "src": "https://tvscientific.com/hubfs/ScalabilityImage.png", "alt": "Scalability dashboard composite", "loading": "lazy", "width": 0, "height": 0 },
        "body_copy": "<p>Spend your ad dollars more effectively, optimize in real time, and jump quickly on new opportunities.</p>",
