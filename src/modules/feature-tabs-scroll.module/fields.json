        "tab_icon": { "size_type": "exact", "src": "https://tvscientific.com/hubfs/Shield.svg", "alt": "Brand Safety icon", "loading": "lazy", "width": 35, "height": 35 },
        "tab_image": { "size_type": "auto", "src": "https://tvscientific.com/hubfs/BrandSafetyImage.png", "alt": "Brand Safety dashboard composite", "loading": "lazy", "width": 0, "height": 0 },
        "body_copy": "<p>Ensure the inventory you can access aligns to the brand values you've worked hard to uphold.</p>",
        "cta": { "show": true, "link": { "url": { "type": "EXTERNAL", "href": "/contact" }, "open_in_new_tab": false, "no_follow": false }, "text": "Learn more" }
