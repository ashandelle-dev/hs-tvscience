[
  {
    "name": "show_header",
    "label": "Show heading above grid",
    "type": "boolean",
    "display": "toggle",
    "default": false
  },

  {
    "name": "eyebrow",
    "label": "Eyebrow",
    "type": "text",
    "allow_new_line": false,
    "visibility": {
      "controlling_field": "show_header",
      "controlling_value_regex": "true",
      "operator": "EQUAL"
    },
    "default": "Performance at scale"
  },

  {
    "name": "heading",
    "label": "Heading",
    "type": "group",
    "tab": "CONTENT",
    "visibility": {
      "controlling_field": "show_header",
      "controlling_value_regex": "true",
      "operator": "EQUAL"
    },
    "children": [
      {
        "name": "value",
        "label": "Heading content",
        "type": "text",
        "allow_new_line": false,
        "default": "See every outcome that matters"
      },
      {
        "name": "header_tag",
        "label": "Heading level",
        "type": "choice",
        "required": true,
        "display": "select",
        "choices": [
          ["h1", "H1"], ["h2", "H2"], ["h3", "H3"], ["h4", "H4"], ["h5", "H5"], ["h6", "H6"], ["p", "P"]
        ],
        "default": "h2"
      },
      {
        "name": "heading_size",
        "label": "Heading Size",
        "type": "number",
        "suffix": "px",
        "inline_help_text": "Set to 0 to use the default size",
        "default": 48
      },
      {
        "name": "heading_size_mobile",
        "label": "Heading Size Mobile",
        "type": "number",
        "suffix": "px",
        "inline_help_text": "Set to 0 to use the default size",
        "default": 36
      },
      {
        "name": "font_weight",
        "label": "Font Weight",
        "type": "choice",
        "display": "select",
        "choices": [["normal", "Normal"], ["semibold", "Semibold"], ["bold", "Bold"]],
        "default": "semibold"
      }
    ]
  },

  {
    "name": "body_copy",
    "label": "Body",
    "type": "richtext",
    "visibility": {
      "controlling_field": "show_header",
      "controlling_value_regex": "true",
      "operator": "EQUAL"
    },
    "default": "<p>Every campaign, every household, every outcome — measured.</p>"
  },

  {
