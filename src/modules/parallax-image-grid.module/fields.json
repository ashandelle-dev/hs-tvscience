  {
    "name": "style",
    "label": "Style",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "name": "parallax",
        "label": "Parallax motion",
        "type": "group",
        "children": [
          {
            "name": "enabled",
            "label": "Enable scroll parallax",
            "type": "boolean",
            "display": "toggle",
            "default": true
          },
          {
            "name": "side_offset",
            "label": "Left / right rise (px)",
            "type": "number",
            "suffix": "px",
            "min": 0,
            "max": 400,
            "inline_help_text": "How far side columns translate upward at full scroll progress.",
            "default": 90
          },
          {
            "name": "center_drift",
            "label": "Center drift (%)",
            "type": "number",
            "suffix": "%",
            "min": 0,
            "max": 50,
            "inline_help_text": "How far the center column drifts downward at full scroll progress.",
            "default": 5
          }
        ]
      },
      {
        "name": "mobile",
        "label": "Mobile layout",
        "type": "group",
        "children": [
          {
            "name": "layout",
            "label": "Mobile layout",
            "type": "choice",
            "display": "select",
            "choices": [
              ["stack", "Stack — single column, all cards"],
              ["two-col", "2 columns — half the height"],
              ["center-only", "Center only — hide side cards"]
            ],
            "inline_help_text": "How the grid collapses on screens <= 768px wide.",
            "default": "two-col"
          }
        ]
      },
      {
        "name": "background_color",
        "label": "Background color",
        "type": "color",
        "default": { "color": null, "opacity": 100 }
      },
      {
        "name": "background_image",
        "label": "Background image",
        "type": "image",
        "responsive": true,
        "resizable": true,
        "show_loading": true,
        "default": { "size_type": "exact", "src": "", "alt": "", "loading": "lazy", "width": 1920, "height": 1080 }
      },
      {
        "name": "text_color",
        "label": "Text color",
        "type": "color",
        "default": { "color": null, "opacity": 100 }
      },
      {
        "name": "padding",
        "label": "Padding",
        "type": "spacing",
        "default": {
          "padding": {
            "top": { "value": 64, "units": "px" },
            "bottom": { "value": 64, "units": "px" }
          }
        }
      }
    ]
  }
